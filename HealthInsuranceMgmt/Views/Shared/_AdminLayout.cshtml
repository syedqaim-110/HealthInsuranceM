@* Views/Shared/_AdminLayout.cshtml *@
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="d-flex" id="wrapper">

        <!-- Sidebar -->
        <div class="bg-dark border-right" id="sidebar-wrapper" style="width: 250px; min-height: 100vh;">
            <div class="sidebar-heading text-white p-3 fw-bold">🏥 Admin Panel</div>
            <div class="list-group list-group-flush">
                <a class="list-group-item list-group-item-action bg-dark text-white" asp-controller="AdminDashboard" asp-action="Index">Dashboard</a>
                <a class="list-group-item list-group-item-action bg-dark text-white" asp-controller="CompanyDetails" asp-action="Index">Insurance Companies</a>
                <a class="list-group-item list-group-item-action bg-dark text-white" asp-controller="Policies" asp-action="Index">Manage Policies</a>
                <a class="list-group-item list-group-item-action bg-dark text-white" asp-controller="PolicyRequests" asp-action="Index">Policy Requests</a>
                <a class="list-group-item list-group-item-action bg-dark text-white" asp-controller="AdminEmployees" asp-action="Index">Manage Employees</a>
                <!-- NAYA FAQ LINK YAHAN ADD HUA HAI -->
                <a class="list-group-item list-group-item-action bg-dark text-white" asp-controller="AdminFAQs" asp-action="Index">Manage FAQs</a>
                <a class="list-group-item list-group-item-action bg-dark text-white" asp-controller="Reports" asp-action="Index">Reports</a>
            </div>
        </div>

        <!-- Page Content -->
        <div id="page-content-wrapper" class="w-100">

            <!-- Top Navbar -->
            <nav class="navbar navbar-expand-lg navbar-light bg-light border-bottom">
                <div class="container-fluid">
                    <span class="navbar-brand mb-0 h1">Health Insurance Management</span>
                    <partial name="_LoginPartial" />
                </div>
            </nav>

            <!-- Main Body -->
            <div class="container-fluid p-4">
                @RenderBody()
            </div>

        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- Validation Scripts (Forms ke liye zaroori) -->
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>