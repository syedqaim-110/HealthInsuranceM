@using HealthInsuranceMgmt.Models.Entities
@using Microsoft.AspNetCore.Identity
@inject SignInManager<EmpRegister> SignInManager
@inject UserManager<EmpRegister> UserManager

@if (SignInManager.IsSignedIn(User))
{
    <div class="flex items-center space-x-3">
        <span class="text-sm text-slate-600 font-medium hidden sm:block">Hello, @UserManager.GetUserName(User)!</span>
        <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post">
            <button type="submit" class="bg-red-500 hover:bg-red-600 text-white px-4 py-2 rounded-lg font-semibold text-xs transition-all flex items-center gap-1.5">
                <i class="fa-solid fa-right-from-bracket"></i> Logout
            </button>
        </form>
    </div>
}
else
{
    <a asp-area="Identity" asp-page="/Account/Login" class="bg-medBlue-600 hover:bg-medBlue-700 text-white px-5 py-2.5 rounded-lg font-semibold text-sm transition-all shadow-md flex items-center gap-2">
        <i class="fa-solid fa-user-shield"></i> Portal Access
    </a>
}