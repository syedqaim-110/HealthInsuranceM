@model IEnumerable<HealthInsuranceMgmt.Models.Entities.EmpRegister>
@{
    ViewData["Title"] = "Manage Employees";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-4">
    <h2>Manage Employees</h2>
    <hr />
    <p>
        <a asp-action="Create" class="btn btn-primary mb-3">+ Add New Employee</a>
    </p>

    <table class="table table-bordered table-hover shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Email (Username)</th>
                <th>Department</th>
                <th>Designation</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.FirstName @item.LastName</td>
                        <td>@item.Email</td>
                        <td>@item.Department</td>
                        <td>@item.Designation</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5" class="text-center text-danger">No employees found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>