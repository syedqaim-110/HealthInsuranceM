@model HealthInsuranceMgmt.Models.Entities.CompanyDetail
@{
    ViewData["Title"] = "Delete Company";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2>Delete Company</h2>
<h4 class="text-danger">Are you sure you want to delete <strong>@Model.CompanyName</strong>?</h4>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger mt-3">Confirm Delete</button>
    <a asp-action="Index" class="btn btn-secondary mt-3">Cancel</a>
</form>