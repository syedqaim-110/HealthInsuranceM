@* Views/Home/About.cshtml *@
@{
    ViewData["Title"] = "About Us";
}

<div class="container py-5">
    <h1 class="mb-4">About Medicare Health Insurance System</h1>

    <div class="row">
        <div class="col-md-8">
            <p class="lead">
                The Medicare Health Insurance Management System is designed to automate
                and streamline the entire health insurance workflow for corporate organizations.
            </p>

            <h4>Our Mission</h4>
            <p>
                To replace manual, spreadsheet-based insurance management with a fully
                integrated, secure, and user-friendly digital solution that saves time,
                reduces errors, and provides real-time visibility into policy and claim status.
            </p>

            <h4>What We Solve</h4>
            <ul>
                <li><strong>Eliminate manual work</strong> — No more spreadsheets and paper forms</li>
                <li><strong>Centralized data</strong> — All employee and policy information in one system</li>
                <li><strong>Real-time tracking</strong> — Know the status of every request instantly</li>
                <li><strong>Role-based access</strong> — Each user sees only what they need</li>
                <li><strong>Secure</strong> — Password-protected with role authorization</li>
            </ul>

            <h4>Key Features</h4>
            <ul>
                <li>Policy search and request for employees</li>
                <li>Policy approval/rejection workflow for administrators</li>
                <li>Claim settlement processing for finance managers</li>
                <li>Comprehensive reporting by date, employee, and policy</li>
            </ul>
        </div>
        <div class="col-md-4">
            <div class="card bg-light shadow-sm">
                <div class="card-body text-center">
                    <h3>🏥</h3>
                    <h5>Medicare</h5>
                    <p class="text-muted">Trusted Insurance Management</p>
                </div>
            </div>
        </div>
    </div>
</div>