                    <div><span class="text-[10px] uppercase text-slate-400 block">Processing Velocity</span><span class="text-xl font-bold text-emerald-300 block">8.5x Faster</span></div>
                </div>
                <button onclick="triggerQuoteRequest()" class="w-full bg-emerald-500 hover:bg-emerald-600 text-slate-950 font-extrabold py-3 rounded-lg text-xs transition-all uppercase tracking-wider flex items-center justify-center gap-2">
