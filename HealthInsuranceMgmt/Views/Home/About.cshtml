        <img src="https://images.unsplash.com/photo-1516549655169-df83a0774514?auto=format&fit=crop&q=80&w=2070" class="w-full h-full object-cover filter blur-[1px]" alt="Modern medical research lab">
    </div>
    <div class="absolute inset-0 bg-gradient-to-r from-medBlue-900 via-medBlue-900/90 to-transparent z-10"></div>
