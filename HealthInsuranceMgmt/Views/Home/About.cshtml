<!-- PAGE SPECIFIC SCRIPTS -->
@section Scripts {
    <script>
        function calculateSavings() {
            const employees = parseFloat(document.getElementById('emp-slider').value);
            const claims = parseFloat(document.getElementById('claim-slider').value);
            document.getElementById('emp-slider-val').innerText = `${employees} Employees`;
            document.getElementById('claim-slider-val').innerText = `${claims} Claims`;
            const totalClaims = employees * claims;
            const hoursManual = totalClaims * 0.75;
            const traditionalCost = hoursManual * 60;
            const digitalCost = traditionalCost * 0.15;
            const hoursSaved = Math.round(hoursManual * 0.85);
            const netCashSaved = Math.round(traditionalCost - digitalCost);
            document.getElementById('calc-hours-saved').innerText = `${hoursSaved} Hrs`;
            document.getElementById('calc-cash-saved').innerText = `$${netCashSaved.toLocaleString()}`;
        }
        function triggerQuoteRequest() { showToast("Your Custom Onboarding Consultation request has been sent successfully!"); }
        function switchTab(tabId) {
            document.querySelectorAll('.tab-panel').forEach(p => p.classList.add('hidden'));
            document.getElementById(`tab-content-${tabId}`).classList.remove('hidden');
            document.querySelectorAll('.tab-button').forEach(b => b.className = "tab-button px-5 py-3 rounded-lg text-xs font-bold transition-all flex items-center gap-2 text-slate-600 hover:bg-slate-200/70");
            document.getElementById(`tab-btn-${tabId}`).className = "tab-button active px-5 py-3 rounded-lg text-xs font-bold transition-all flex items-center gap-2 bg-medBlue-600 text-white shadow-sm";
        }
        function openBioModal(name, role, bio, email) {
            document.getElementById('modal-name').innerText = name;
            document.getElementById('modal-title').innerText = role;
            document.getElementById('modal-bio').innerText = bio;
            document.getElementById('modal-email').innerText = email;
            document.getElementById('modal-email').href = `mailto:${email}`;
            document.getElementById('bio-modal').classList.remove('hidden');
        }
        function closeBioModal() { document.getElementById('bio-modal').classList.add('hidden'); }
        window.onload = function() { calculateSavings(); };
    </script>
}