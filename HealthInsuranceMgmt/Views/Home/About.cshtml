                <div class="absolute -top-12 -right-12 w-24 h-24 bg-emerald-500/10 rounded-full"></div>
                <div>
                    <span class="text-xs uppercase tracking-widest text-emerald-300 font-bold block mb-1">Estimated Annual Savings</span>
                    <span class="text-4xl sm:text-5xl font-black text-white block tracking-tight" id="calc-cash-saved">$33,750</span>
                    <span class="text-xs text-slate-400 block mt-1">in administrative overhead costs</span>
