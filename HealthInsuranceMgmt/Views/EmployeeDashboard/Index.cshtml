@* Views/EmployeeDashboard/Index.cshtml *@
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_EmployeeLayout.cshtml";
}

<div class="container mt-4">
    <h1>Welcome to your Dashboard</h1>
    <hr />
    <p class="lead">Yahan aap naye health insurance policies search kar sakte hain aur apni requests ka status track kar sakte hain.</p>

    <div class="row mt-4">
        <div class="col-md-4">
            <div class="card text-white bg-primary mb-3" style="max-width: 18rem;">
                <div class="card-header">Action</div>
                <div class="card-body">
                    <h5 class="card-title">Search Policy</h5>
                    <p class="card-text">Naye insurance plans dekhein.</p>
                    <a asp-controller="EmployeePolicies" asp-action="Index" class="btn btn-light">View Policies</a>
                </div>
            </div>
        </div>
    </div>
</div>